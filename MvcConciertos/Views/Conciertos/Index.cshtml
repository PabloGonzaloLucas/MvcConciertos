@model IEnumerable<MvcConciertos.Models.Evento>

@{
    ViewData["Title"] = "Index";
    List<CategoriaEvento> categorias = ViewBag.Categorias as List<CategoriaEvento>;
}

<h1>Index</h1>
<div class="mb-4">
    <label for="preguntaTextarea" class="form-label">Pregunta a la IA</label>
    <div class="input-group">
        <textarea id="preguntaTextarea" class="form-control" rows="3" placeholder="Escribe tu pregunta aquí..."></textarea>
        <button id="btnEnviarPregunta" class="btn btn-primary">Enviar</button>
    </div>
    <div id="respuestaIA" class="mt-2 alert alert-secondary" style="display:none;"></div>
</div>

<ul>
    @foreach (var categoria in categorias)
    {
        <li>
            <a asp-action="Index" asp-controller="Conciertos" asp-route-idCategoria=@categoria.IdCategoria>@categoria.Nombre</a>
        </li>
    }
</ul>


<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.IdEvento)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Nombre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Artista)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Imagen)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IdCategoria)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.IdEvento)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Nombre)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Artista)
            </td>
            <td>
                <img src="https://s3-examen-pgl.s3.us-east-1.amazonaws.com/@item.Imagen" style="width:100px; height:100px;" 
                    />
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdCategoria)
            </td>
            <td>
                @Html.ActionLink("Edit", "Edit", new { /* id=item.PrimaryKey */ }) |
                @Html.ActionLink("Details", "Details", new { /* id=item.PrimaryKey */ }) |
                @Html.ActionLink("Delete", "Delete", new { /* id=item.PrimaryKey */ })
            </td>
        </tr>
}
    </tbody>
</table>

<script>
    (function(){
        const btn = document.getElementById('btnEnviarPregunta');
        const textarea = document.getElementById('preguntaTextarea');
        const respuestaDiv = document.getElementById('respuestaIA');

        btn.addEventListener('click', async function(e){
            e.preventDefault();
            const pregunta = textarea.value && textarea.value.trim();
            if (!pregunta) {
                respuestaDiv.style.display = '';
                respuestaDiv.className = 'mt-2 alert alert-warning';
                respuestaDiv.textContent = 'Introduce una pregunta.';
                return;
            }

            respuestaDiv.style.display = '';
            respuestaDiv.className = 'mt-2 alert alert-info';
            respuestaDiv.textContent = 'Enviando...';

            try {
                const url = '@Url.Action("GetRespuestaIA","Conciertos")';
                const body = new URLSearchParams();
                body.append('pregunta', pregunta);

                const resp = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: body
                });

                if (!resp.ok) throw new Error('Error en la petición: ' + resp.status);
                const data = await resp.json();
                respuestaDiv.className = 'mt-2 alert alert-success';
                respuestaDiv.textContent = data || '(sin respuesta)';
            }
            catch (err) {
                respuestaDiv.className = 'mt-2 alert alert-danger';
                respuestaDiv.textContent = err && err.message ? err.message : String(err);
            }
        });
    })();
</script>

